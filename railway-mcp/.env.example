# Railway MCP server — local/dev configuration.
# On Railway, set these as service variables instead of using this file.

# Auth is "Login with Railway" (OAuth/OIDC). There is no password.

# OPTIONAL: a static Railway API token. If set, the server calls the Railway
# API with THIS token. If unset (recommended), it calls the API as the
# logged-in user, using their Login-with-Railway session — no token to paste.
RAILWAY_API_TOKEN=

# OPTIONAL: pre-registered "Login with Railway" OAuth app
# (workspace settings -> Developer -> New OAuth App). If unset, the server
# self-registers via Dynamic Client Registration at boot.
RAILWAY_OAUTH_CLIENT_ID=
RAILWAY_OAUTH_CLIENT_SECRET=

# OPTIONAL: comma-separated Railway emails allowed to use this connector.
# If empty, the first verified login becomes the owner and is the only one
# allowed thereafter (trust-on-first-use).
ALLOWED_RAILWAY_EMAILS=

# OPTIONAL: override the requested OAuth scope.
# RAILWAY_OAUTH_SCOPE=openid email profile offline_access workspace:admin

# Auto-set by the template on Railway. For local dev, leave as-is.
PUBLIC_URL=http://localhost:3000
DATA_DIR=./data

# Optional: Discord webhook for security/activity alerts (off unless set).
DISCORD_WEBHOOK_URL=
MCP_ACTIVITY_ALERTS=false
