# Railway MCP server — local/dev configuration.
# On Railway, set these as service variables instead of using this file.

# Required: a Railway API token (railway.com/account/tokens).
RAILWAY_API_TOKEN=

# Required: the password you'll type on the OAuth page when adding the
# connector in Claude. Make it long and random.
AUTH_PASSWORD=

# Auto-set by the template on Railway. For local dev, leave as-is.
PUBLIC_URL=http://localhost:3000
DATA_DIR=./data

# Optional: Discord webhook for security/activity alerts (off unless set).
DISCORD_WEBHOOK_URL=
# Set to true to alert on session start + destructive tool calls.
MCP_ACTIVITY_ALERTS=false
