# GitHub MCP server — local/dev configuration.
# On Railway, set these as service variables instead of using this file.

# Auth is "Login with Railway" (OAuth/OIDC) for the connecting human. The
# GitHub API itself is called with the token below. There is no password.

# REQUIRED: a GitHub Personal Access Token. Recommended: a fine-grained token
# with Contents + Pull requests + Administration = Read/write and Metadata =
# Read (Administration is what enables creating repos). A classic `repo`-scope
# token also works, but is broader (full access to every repo you can reach).
GITHUB_TOKEN=

# OPTIONAL: pre-registered "Login with Railway" OAuth app. If unset, the server
# self-registers via Dynamic Client Registration at boot.
RAILWAY_OAUTH_CLIENT_ID=
RAILWAY_OAUTH_CLIENT_SECRET=

# OPTIONAL: comma-separated Railway emails allowed to use this connector.
# If empty, the first verified login becomes the owner (trust-on-first-use).
ALLOWED_RAILWAY_EMAILS=

# Auto-set by the template on Railway. For local dev, leave as-is.
PUBLIC_URL=http://localhost:3000
DATA_DIR=./data

# Optional: Discord webhook for security/activity alerts (off unless set).
DISCORD_WEBHOOK_URL=
MCP_ACTIVITY_ALERTS=false
