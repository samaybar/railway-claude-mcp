# Combined Railway + GitHub MCP server — local/dev configuration.
# On Railway, set these as service variables instead of using this file.
#
# Auth is "Login with Railway" (OAuth/OIDC). There is no password.

# OPTIONAL: static Railway API token. If unset (default), Railway tools call
# the API as the logged-in user via their Login-with-Railway session.
RAILWAY_API_TOKEN=

# Enables the GitHub toolset. If unset, only the Railway tools are exposed.
# Recommended: a fine-grained token with Contents + Pull requests +
# Administration = Read/write and Metadata = Read (Administration enables
# creating repos). A classic `repo`-scope token also works (broader access).
GITHUB_TOKEN=

# OPTIONAL: pre-registered "Login with Railway" OAuth app. If unset, the server
# self-registers via Dynamic Client Registration at boot.
RAILWAY_OAUTH_CLIENT_ID=
RAILWAY_OAUTH_CLIENT_SECRET=

# OPTIONAL: comma-separated Railway emails allowed to use this connector.
# If empty, the first verified login becomes the owner (trust-on-first-use).
ALLOWED_RAILWAY_EMAILS=

# Auto on Railway (PUBLIC_URL derives from RAILWAY_PUBLIC_DOMAIN). For local dev:
PUBLIC_URL=http://localhost:3000
DATA_DIR=./data

# Optional Discord alerts.
DISCORD_WEBHOOK_URL=
MCP_ACTIVITY_ALERTS=false
