# Combined Railway + GitHub MCP server — local/dev configuration.
# On Railway, set these as service variables instead of using this file.
#
# Auth is "Login with Railway" (OAuth/OIDC). There is no password.

# Capability scoping (least privilege):
#   RAILWAY_MODE = read | deploy (default) | full   (full adds delete)
#   GITHUB_MODE  = off | read | write (default)      (off hides GitHub entirely)
RAILWAY_MODE=deploy
GITHUB_MODE=write

# OPTIONAL: static Railway API token. Leave this BLANK for normal use — Railway
# tools call the API as the logged-in user via their Login-with-Railway session,
# and the server keeps that session alive automatically (it refreshes the token
# and, if the session truly expires, asks you to reconnect). Only set this for
# unattended or shared deployments where there's no human to reconnect, or where
# every connection should act as one fixed service identity. Use an account
# token (Railway → Account Settings → Tokens), not a project token.
RAILWAY_API_TOKEN=

# OPTIONAL static GitHub token (fallback). The preferred way to turn on GitHub
# is the github-connect tool (GitHub App device flow). If you do set one:
# fine-grained with Contents + Pull requests + Administration = Read/write and
# Metadata = Read (Administration enables creating repos); or classic `repo`.
GITHUB_TOKEN=

# OPTIONAL: pre-registered "Login with Railway" OAuth app. If unset, the server
# self-registers via Dynamic Client Registration at boot.
RAILWAY_OAUTH_CLIENT_ID=
RAILWAY_OAUTH_CLIENT_SECRET=

# OPTIONAL: comma-separated Railway emails allowed to use this connector.
# If empty, the first verified login becomes the owner (trust-on-first-use).
ALLOWED_RAILWAY_EMAILS=

# Auto on Railway (PUBLIC_URL derives from RAILWAY_PUBLIC_DOMAIN). For local dev:
PUBLIC_URL=http://localhost:3000
DATA_DIR=./data

# Optional Discord alerts.
DISCORD_WEBHOOK_URL=
MCP_ACTIVITY_ALERTS=false
